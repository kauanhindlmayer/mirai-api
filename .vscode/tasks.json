{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/Mirai.slnx",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/Mirai.slnx",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "command": "dotnet",
      "type": "process",
      "args": ["watch", "run", "--project", "${workspaceFolder}/Mirai.slnx"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "restore",
      "command": "dotnet",
      "type": "process",
      "args": ["restore", "${workspaceFolder}/Mirai.slnx"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "command": "dotnet",
      "type": "process",
      "args": ["clean", "${workspaceFolder}/Mirai.slnx"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "format",
      "command": "dotnet",
      "type": "process",
      "args": ["format", "${workspaceFolder}/Mirai.slnx"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "command": "dotnet",
      "type": "process",
      "args": ["test", "${workspaceFolder}/Mirai.slnx"],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test with coverage",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/Mirai.slnx",
        "--collect:XPlat Code Coverage"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "ef: add migration",
      "command": "dotnet",
      "type": "process",
      "args": ["ef", "migrations", "add", "${input:migrationName}"],
      "options": {
        "cwd": "${workspaceFolder}/src/Presentation"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "ef: update database",
      "command": "dotnet",
      "type": "process",
      "args": ["ef", "database", "update"],
      "options": {
        "cwd": "${workspaceFolder}/src/Presentation"
      },
      "problemMatcher": "$msCompile"
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Migration name"
    }
  ]
}
