{
  "ConnectionStrings": {
    "Database": "",
    "Redis": "mirai.redis:6379",
    "BlobStorage": ""
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://mirai.aspire-dashboard:18889",
          "Protocol": "Grpc",
          "ResourceAttributes": {
            "service.name": "mirai-api"
          }
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "Mirai-Development"
    }
  },
  "Authentication": {
    "Audience": "account",
    "ValidIssuer": "http://mirai.idp:8080/realms/mirai",
    "MetadataAddress": "http://mirai.idp:8080/realms/mirai/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "Keycloak": {
    "BaseUrl": "http://mirai.idp:8080",
    "AdminUrl": "http://mirai.idp:8080/admin/realms/mirai/",
    "TokenUrl": "http://mirai.idp:8080/realms/mirai/protocol/openid-connect/token",
    "AdminClientId": "",
    "AdminClientSecret": "",
    "AuthClientId": "",
    "AuthClientSecret": ""
  },
  "EmbeddingService": {
    "BaseUrl": "http://mirai.embedding-api:8000",
    "ApiKey": ""
  }
}
